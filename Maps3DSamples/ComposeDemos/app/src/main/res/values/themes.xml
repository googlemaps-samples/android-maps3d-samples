<resources>
    <!--
    A custom "Boulder Nature Hippie" theme for the PlaceDetailsCompactFragment.
    This theme overrides multiple attributes to create an earthy, natural look.
    -->
    <style name="BoulderNatureHippieTheme" parent="PlacesMaterialTheme">
        <!-- Core Colors -->
        <item name="placesColorSurface">#FFFDF5</item> <!-- Warm Cream/Beige -->
        <item name="placesColorPrimary">#2C5E3B</item> <!-- Forest Green -->
        <item name="placesColorOnSurface">#3E2723</item> <!-- Dark Brown -->
        <item name="placesColorOnSurfaceVariant">#5D4037</item> <!-- Medium Brown -->
        <item name="placesColorOutlineDecorative">#D7CCC8</item> <!-- Sand/Light Brown -->

        <!-- Status Colors -->
        <item name="placesColorPositive">#4CAF50</item> <!-- Leaf Green -->
        <item name="placesColorNegative">#D32F2F</item> <!-- Earthy Red -->

        <!-- Shape -->
        <item name="placesCornerRadius">16dp</item> <!-- More rounded, organic feel -->
    </style>
</resources>
